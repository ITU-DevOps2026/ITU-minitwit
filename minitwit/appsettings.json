{
  "Serilog": {
    "Using": ["Serilog.Sinks.Elasticsearch", "Serilog.Enrichers.Sensitive", "Serilog.Expressions"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath like '/metrics'"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithSensitiveDataMasking"],
    "WriteTo": [
      { 
        "Name": "Elasticsearch", 
        "Args": {
          "bootstrapMethod": "Silent",
          "nodes": ["http://elasticsearch:9200"]}}
    ]
  },
  "AllowedHosts": "*"
}